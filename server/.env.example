ANTHROPIC_API_KEY=
PORT=5050
# Optional: comma-separated browser origins (default = allow all)
# CORS_ORIGIN=http://localhost:5173
# Optional: max AI generations per IP per 15 minutes (default 40)
# GENERATE_RATE_LIMIT_MAX=40
# Optional: trust X-Forwarded-* when behind a reverse proxy (needed for correct rate-limit IPs)
# TRUST_PROXY=1
# Optional: require Bearer or X-War-Room-Key on POST /api/problem and /api/screening
# WAR_ROOM_API_KEY=
# Must match client VITE_WAR_ROOM_API_KEY when both are set

# Optional: lock the whole app behind login (browser cookie session).
# Super user (aliases: WAR_ROOM_SUPER_USER / WAR_ROOM_SUPER_PASSWORD):
# WAR_ROOM_APP_USER / WAR_ROOM_APP_PASSWORD = super user (long session, can create guest passes).
# Guests: super creates passes via UI; guest logins use short cookie + pass expires after WAR_ROOM_GUEST_HOURS.
# If WAR_ROOM_APP_USER is set, you must also set WAR_ROOM_APP_PASSWORD and
# WAR_ROOM_SESSION_SECRET (min 16 chars). Leave WAR_ROOM_APP_USER unset for open access.
# WAR_ROOM_APP_USER=
# WAR_ROOM_APP_PASSWORD=
# (same as above, if you prefer these names:)
# WAR_ROOM_SUPER_USER=
# WAR_ROOM_SUPER_PASSWORD=
# WAR_ROOM_SESSION_SECRET=
# Guest pass lifetime in hours (default 3). Guest session cookie is capped to remaining time.
# WAR_ROOM_GUEST_HOURS=3
# Optional: max guest session cookie seconds (default 10800 = 3h)
# WAR_ROOM_GUEST_SESSION_SEC=10800
# Optional: super user session seconds (default 7 days)
# WAR_ROOM_SUPER_SESSION_SEC=604800
# Optional: force Secure cookies (defaults true when NODE_ENV=production)
# COOKIE_SECURE=1
